{
    "input_repository_url": "https://github.com/rust-lang/rust-analyzer",
    "input_repository_json_configuration_path": "editors/code/package.json",
    "transformers": [
        {
            "type": "jq",
            "options": "[.contributes.configuration[].properties | select(. != null)] | add"
        },
        {
            "type": "jq",
            "options": "walk(if type == \"object\" then with_entries(if .key == \"description\" then .key = \"markdownDescription\" else . end) else . end)"
        },
        {
            "type": "jq",
            "options": "walk(if type == \"object\" then with_entries(if .key == \"enumDescriptions\" then .key = \"markdownEnumDescriptions\" else . end) else . end)"
        },
        {
            "type": "prepend_keys",
            "options": {
                "terminusAutoClose": {
                    "default": false,
                    "description": "Whether or not to automatically close terminus panel/tab upon completion.",
                    "type": "boolean"
                },
                "terminusUsePanel": {
                    "default": false,
                    "description": "Whether or not to spawn a panel at the bottom, or a new tab.",
                    "type": "boolean"
                }
            }
        },
        {
            "type": "jq",
            "options": "with_entries(.key |= ltrimstr(\"rust-analyzer.\"))"
        },
        {
            "type": "remove_keys",
            "options": [
                "debug.buildBeforeRestart",
                "debug.engine",
                "debug.engineSettings",
                "debug.openDebugPane",
                "debug.sourceFileMap",
                "initializeStopped",
                "projectCreation.openAfterCreate",
                "restartServerOnConfigChange",
                "runnables.askBeforeUpdateTest",
                "runnables.problemMatcher",
                "server.extraEnv",
                "server.path",
                "showDependenciesExplorer",
                "showRequestFailedErrorNotification",
                "showSyntaxTree",
                "showUnlinkedFileNotification",
                "statusBar.clickAction",
                "statusBar.showStatusBar",
                "testExplorer",
                "testExplorer",
                "trace.extension",
                "trace.server"
            ]
        }
    ],
    "render_templates": [
        {
            "type": "settings",
            "template_path": "templates/sublime-settings.jinja.json",
            "output_path": "LSP-rust-analyzer.sublime-settings"
        },
        {
            "type": "schema",
            "template_path": "templates/sublime-package.jinja.json",
            "output_path": "sublime-package.json"
        }
    ]
}
